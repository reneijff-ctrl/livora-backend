{
  "dashboard": {
    "id": null,
    "uid": "mediasoup-failures",
    "title": "Mediasoup — Failures Dashboard",
    "tags": ["mediasoup", "failures", "livora"],
    "timezone": "browser",
    "refresh": "10s",
    "time": { "from": "now-1h", "to": "now" },
    "panels": [
      {
        "id": 1,
        "title": "Node Availability",
        "type": "stat",
        "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
        "targets": [
          { "expr": "count(up{job=\"mediasoup\"} == 1)", "legendFormat": "Healthy" }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "orange", "value": 1 },
                { "color": "green", "value": 2 }
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Node Failures (total)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
        "targets": [
          { "expr": "mediasoup_cluster_node_failures_total", "legendFormat": "Failures" }
        ]
      },
      {
        "id": 3,
        "title": "Stream Restarts (total)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
        "targets": [
          { "expr": "mediasoup_cluster_stream_restarts_total", "legendFormat": "Restarts" }
        ]
      },
      {
        "id": 4,
        "title": "Reconnect Attempts vs Successes",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
        "targets": [
          { "expr": "increase(mediasoup_cluster_reconnect_attempts_total[5m])", "legendFormat": "Attempts" },
          { "expr": "increase(mediasoup_cluster_successful_recoveries_total[5m])", "legendFormat": "Successes" }
        ]
      },
      {
        "id": 5,
        "title": "Reconnect Success Rate",
        "type": "gauge",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
        "targets": [
          {
            "expr": "mediasoup_cluster_successful_recoveries_total / clamp_min(mediasoup_cluster_reconnect_attempts_total, 1) * 100",
            "legendFormat": "Success %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "orange", "value": 80 },
                { "color": "green", "value": 95 }
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "Scrape Target Status",
        "type": "table",
        "gridPos": { "h": 6, "w": 24, "x": 0, "y": 12 },
        "targets": [
          { "expr": "up{job=\"mediasoup\"}", "legendFormat": "{{ instance }}", "format": "table", "instant": true }
        ]
      }
    ],
    "schemaVersion": 39
  },
  "overwrite": true
}
