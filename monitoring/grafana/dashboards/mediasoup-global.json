{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "title": "Global Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Total Viewers (Global)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "mediasoup_cluster_total_consumers",
          "legendFormat": "Viewers"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      }
    },
    {
      "title": "Healthy Nodes",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "targets": [
        {
          "expr": "mediasoup_cluster_nodes_healthy",
          "legendFormat": "Healthy"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 2 }
            ]
          }
        }
      }
    },
    {
      "title": "Stream Restarts (Total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "targets": [
        {
          "expr": "mediasoup_cluster_stream_restarts_total",
          "legendFormat": "Restarts"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "title": "Scale Events",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "mediasoup_cluster_scale_up_events_total",
          "legendFormat": "Scale Up"
        },
        {
          "expr": "mediasoup_cluster_scale_down_events_total",
          "legendFormat": "Scale Down"
        }
      ]
    },
    {
      "title": "Node Failures",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "targets": [
        {
          "expr": "mediasoup_cluster_node_failures_total",
          "legendFormat": "Failures"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Recovery Rate",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "targets": [
        {
          "expr": "mediasoup_cluster_successful_recoveries_total / (mediasoup_cluster_reconnect_attempts_total > 0 or vector(1)) * 100",
          "legendFormat": "Recovery %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "title": "Per-Region Metrics",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "title": "Viewers per Region",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "sum by (region) (mediasoup_node_consumers)",
          "legendFormat": "{{region}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "pointSize": 5,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "title": "Healthy Nodes per Region",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "sum by (region) (mediasoup_node_healthy)",
          "legendFormat": "{{region}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "lineWidth": 1
          }
        }
      }
    },
    {
      "title": "Latency per Region",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, region) (rate(mediasoup_health_check_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{region}}"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le, region) (rate(mediasoup_health_check_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{region}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "title": "Traffic Distribution (Pie)",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "sum by (region) (mediasoup_node_consumers)",
          "legendFormat": "{{region}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "pieType": "donut"
      }
    },
    {
      "title": "Cross-Region Failover Events",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false
    },
    {
      "title": "Failover Timeline",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 23 },
      "targets": [
        {
          "expr": "mediasoup_cluster_stream_restarts_total",
          "legendFormat": "Stream Restarts"
        },
        {
          "expr": "mediasoup_cluster_node_failures_total",
          "legendFormat": "Node Failures"
        },
        {
          "expr": "mediasoup_cluster_reconnect_attempts_total",
          "legendFormat": "Reconnect Attempts"
        },
        {
          "expr": "mediasoup_cluster_successful_recoveries_total",
          "legendFormat": "Successful Recoveries"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5
          }
        }
      }
    }
  ],
